<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Call History view — recent calls table with direction filter and call-back.
  Controller: CallHistoryController (set via FXMLLoader.setController before load).
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1" styleClass="view-root">

    <top>
        <VBox spacing="10">

            <!-- Toolbar: title · search · direction · refresh -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="view-header">
                <Label text="Call History" styleClass="view-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField"
                           promptText="Search by name, company, or number"
                           prefWidth="260"
                           styleClass="search-field"/>
                <HBox alignment="CENTER" styleClass="segmented">
                    <ToggleButton fx:id="allBtn"      text="All"/>
                    <ToggleButton fx:id="inboundBtn"  text="Inbound"/>
                    <ToggleButton fx:id="outboundBtn" text="Outbound"/>
                </HBox>
                <Button text="Refresh" onAction="#onRefresh" styleClass="flat"/>
            </HBox>

            <!-- Outcome filter chips (multi-select) -->
            <HBox fx:id="chipBar" spacing="8" alignment="CENTER_LEFT" styleClass="chip-bar">
                <padding><Insets left="32" right="32"/></padding>
                <ToggleButton fx:id="chipCallbacks"  text="Callbacks"   styleClass="filter-chip"/>
                <ToggleButton fx:id="chipNoAnswer"   text="No answer"   styleClass="filter-chip"/>
                <ToggleButton fx:id="chipInterested" text="Interested"  styleClass="filter-chip"/>
                <ToggleButton fx:id="chipVoicemail"  text="Voicemail"   styleClass="filter-chip"/>
                <ToggleButton fx:id="chipDnc"        text="DNC"         styleClass="filter-chip"/>
            </HBox>

            <!-- Pinned callbacks band is inserted here in code -->
            <VBox fx:id="bandHost">
                <padding><Insets left="24" right="24"/></padding>
            </VBox>
        </VBox>
    </top>

    <center>
        <ListView fx:id="list" styleClass="data-list">
            <BorderPane.margin><Insets left="20" right="24" top="8" bottom="0"/></BorderPane.margin>
        </ListView>
    </center>

    <bottom>
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <padding><Insets top="12" bottom="20" left="32" right="32"/></padding>
            <Label fx:id="countLabel" styleClass="caption"/>
        </HBox>
    </bottom>

</BorderPane>
