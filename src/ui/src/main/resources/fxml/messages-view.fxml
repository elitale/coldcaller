<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Messages view — two-pane SMS inbox: conversation list (left) + thread + compose (right).
  Controller: MessagesController (set via FXMLLoader.setController before load).
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1">

    <!-- ── Page header ─────────────────────────────────────────────────────── -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="24" bottom="16" left="32" right="32"/></padding>
            <Label text="Messages" styleClass="title-1"/>
        </HBox>
    </top>

    <!-- ── Two-pane body ───────────────────────────────────────────────────── -->
    <center>
        <HBox spacing="0">

            <!-- ── Left: conversation list ────────────────────────────────── -->
            <VBox prefWidth="240" minWidth="180" styleClass="bg-subtle" spacing="0">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" bottom="8" left="12" right="12"/></padding>
                    <Label text="Conversations" styleClass="label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="newMessageBtn" text="New"
                            styleClass="accent" onAction="#onNewMessage"/>
                </HBox>
                <Separator/>
                <ListView fx:id="conversationList" VBox.vgrow="ALWAYS"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <!-- ── Right: thread + compose ────────────────────────────────── -->
            <BorderPane HBox.hgrow="ALWAYS">

                <!-- Thread header -->
                <top>
                    <VBox spacing="4">
                        <padding><Insets top="16" bottom="0" left="24" right="24"/></padding>
                        <Label fx:id="threadHeader" text="Select a conversation"
                               styleClass="title-2"/>
                        <Label fx:id="threadSubtitle" text="" styleClass="caption"/>
                        <Separator>
                            <VBox.margin><Insets top="8"/></VBox.margin>
                        </Separator>
                    </VBox>
                </top>

                <!-- Thread messages -->
                <center>
                    <ListView fx:id="threadList"/>
                </center>

                <!-- Compose bar -->
                <bottom>
                    <VBox spacing="8">
                        <padding><Insets top="0" bottom="16" left="16" right="16"/></padding>
                        <Separator/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <padding><Insets top="4" bottom="0"/></padding>
                            <Label text="From:" styleClass="caption"/>
                            <ComboBox fx:id="fromNumberCombo" promptText="Select number"
                                      prefWidth="180"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER">
                            <TextField fx:id="composeField"
                                       promptText="Type a message…"
                                       HBox.hgrow="ALWAYS"
                                       onAction="#onSend"/>
                            <Button fx:id="sendBtn" text="Send"
                                    styleClass="accent" onAction="#onSend"/>
                        </HBox>
                    </VBox>
                </bottom>

            </BorderPane>
        </HBox>
    </center>

</BorderPane>
