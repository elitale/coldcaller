<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Messages view — two-pane SMS inbox: conversation list (left) + thread + compose (right).
  Controller: MessagesController (set via FXMLLoader.setController before load).
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1" styleClass="view-root">

    <!-- ── Page header ─────────────────────────────────────────────────────── -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="view-header">
            <Label text="Messages" styleClass="view-title"/>            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="refreshBtn" text="Refresh" styleClass="flat" onAction="#onRefresh"/>        </HBox>
    </top>

    <!-- ── Two-pane body ───────────────────────────────────────────────────── -->
    <center>
        <HBox spacing="0">

            <!-- ── Left: conversation list ────────────────────────────────── -->
            <VBox prefWidth="300" minWidth="220" styleClass="sidebar" spacing="0">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="14" bottom="10" left="16" right="12"/></padding>
                    <Label text="Conversations" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="newMessageBtn" text="New"
                            styleClass="accent" onAction="#onNewMessage"/>
                </HBox>
                <ListView fx:id="conversationList" VBox.vgrow="ALWAYS" styleClass="messages-list"/>
            </VBox>

            <!-- ── Right: thread + compose ────────────────────────────────── -->
            <BorderPane HBox.hgrow="ALWAYS" styleClass="thread-pane">

                <!-- Thread header -->
                <top>
                    <VBox spacing="4">
                        <padding><Insets top="18" bottom="0" left="28" right="28"/></padding>
                        <Label fx:id="threadHeader" text="Select a conversation"
                               styleClass="title-2"/>
                        <Label fx:id="threadSubtitle" text="" styleClass="caption"/>
                        <Label fx:id="optOutBanner" visible="false"
                               text="Opted out — texting disabled"
                               styleClass="opt-out-banner"/>
                        <Separator>
                            <VBox.margin><Insets top="10"/></VBox.margin>
                        </Separator>
                    </VBox>
                </top>

                <!-- Thread messages -->
                <center>
                    <ListView fx:id="threadList" styleClass="thread-list">
                        <BorderPane.margin><Insets left="8" right="8"/></BorderPane.margin>
                    </ListView>
                </center>

                <!-- Compose bar -->
                <bottom>
                    <VBox spacing="7" styleClass="compose-bar">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="From" styleClass="compose-from"/>
                            <ComboBox fx:id="fromNumberCombo" promptText="Select number"
                                      prefWidth="190"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER">
                            <TextField fx:id="composeField"
                                       promptText="Message"
                                       HBox.hgrow="ALWAYS"
                                       styleClass="compose-field"
                                       onAction="#onSend"/>
                            <Button fx:id="sendBtn" onAction="#onSend"/>
                        </HBox>
                        <Label fx:id="composeHint" visible="false" styleClass="caption"/>
                    </VBox>
                </bottom>

            </BorderPane>
        </HBox>
    </center>

</BorderPane>
