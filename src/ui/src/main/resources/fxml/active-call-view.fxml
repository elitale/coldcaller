<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import com.elitale.coldbirds.coldcalling.ui.support.AudioWaveform?>

<!--
  In-window calling screen — header (•••), pulsing avatar + identity (name,
  number, country + local time), live status, primary controls (Mute · Keypad ·
  Hold · Voicemail · Hang Up — plus Redial in the wrap-up / failed phase), a
  collapsible DTMF keypad overlay, disposition chips, and notes. After a call ends it stays in a wrap-up state so the rep can
  finish logging before "Save & Close".
  Controller: ActiveCallController (set via FXMLLoader.setController before load).
  Icons, keypad/chip grids, motion and tones are driven in the controller.
  Keyboard shortcuts (handled at scene level in MainWindow):
    Esc → Hang Up · M Mute · H Hold · K Keypad · 1–8 Disposition · digits DTMF
-->
<VBox fx:id="callingScreen" xmlns:fx="http://javafx.com/fxml/1"
      spacing="14" alignment="TOP_CENTER" maxWidth="600" styleClass="calling-screen">
    <padding><Insets top="18" bottom="26" left="44" right="44"/></padding>

    <!-- Header: ••• menu, top-right (disabled until mid-call device switch ships) -->
    <HBox alignment="CENTER_RIGHT" maxWidth="Infinity">
        <Button fx:id="closeButton" styleClass="flat"/>
    </HBox>

    <!-- Avatar with pulsing halo + state ring -->
    <StackPane maxWidth="150" maxHeight="150" prefWidth="150" prefHeight="150">
        <Region fx:id="haloCircle" styleClass="call-halo" maxWidth="120" maxHeight="120"
                prefWidth="120" prefHeight="120" mouseTransparent="true" visible="false"/>
        <Region fx:id="rippleCircle" styleClass="call-ripple" maxWidth="120" maxHeight="120"
                prefWidth="120" prefHeight="120" mouseTransparent="true" visible="false"/>
        <StackPane fx:id="avatarRing" styleClass="call-ring" maxWidth="104" maxHeight="104"
                   prefWidth="104" prefHeight="104">
            <Label fx:id="avatarLabel" text="?" styleClass="call-avatar"/>
        </StackPane>
    </StackPane>

    <!-- Identity -->
    <VBox spacing="3" alignment="CENTER" maxWidth="Infinity">
        <Label fx:id="remotePartyLabel" text="Connecting…" styleClass="title-1"
               alignment="CENTER" maxWidth="Infinity"/>
        <Label fx:id="numberLabel" text="" styleClass="call-number"
               alignment="CENTER" maxWidth="Infinity" visible="false" managed="false"/>
        <Label fx:id="locationLabel" text="" styleClass="call-location"
               alignment="CENTER" maxWidth="Infinity" visible="false" managed="false"/>
    </VBox>

    <Label fx:id="statusLabel" text="" styleClass="call-status"
           alignment="CENTER" maxWidth="Infinity"/>

    <!-- Recording indicator — visible only while the call is being recorded -->
    <HBox fx:id="recChip" spacing="6" alignment="CENTER" styleClass="call-rec"
          visible="false" managed="false">
        <Region styleClass="call-rec-dot" maxWidth="9" maxHeight="9"
                prefWidth="9" prefHeight="9" minWidth="9" minHeight="9"/>
        <Label text="REC" styleClass="call-rec-text"/>
    </HBox>

    <!-- Live mic meter — visible only while connected -->
    <HBox fx:id="micMeterRow" spacing="9" alignment="CENTER" maxWidth="Infinity"
          visible="false" managed="false">
        <Label fx:id="micStateIcon"/>
        <AudioWaveform fx:id="micMeter" width="240" height="38"/>
    </HBox>

    <!-- Primary controls -->
    <HBox spacing="18" alignment="CENTER">
        <Button fx:id="muteButton"      onAction="#onMuteToggle"   styleClass="call-control"/>
        <Button fx:id="keypadButton"    onAction="#onKeypadToggle" styleClass="call-control"/>
        <Button fx:id="holdButton"      onAction="#onHoldToggle"   styleClass="call-control"/>
        <Button fx:id="outputButton"    onAction="#onCycleOutput"  styleClass="call-control"/>
        <Button fx:id="voicemailButton" styleClass="call-control"/>
        <Button fx:id="redialButton"    onAction="#onRedial"
                styleClass="call-control" visible="false" managed="false"/>
        <Button fx:id="hangUpButton"    onAction="#onHangUp"
                styleClass="call-control, call-control--danger"/>
    </HBox>

    <!-- DTMF keypad overlay (collapsed by default) -->
    <VBox fx:id="keypadOverlay" spacing="10" alignment="CENTER"
          visible="false" managed="false" styleClass="keypad-overlay" focusTraversable="true">
        <Label fx:id="dtmfReadout" text="" styleClass="dtmf-readout"
               alignment="CENTER" maxWidth="Infinity"/>
        <GridPane fx:id="keypadGrid" hgap="10" vgap="10" alignment="CENTER"/>
    </VBox>

    <!-- Disposition chips -->
    <FlowPane fx:id="dispositionChips" hgap="8" vgap="8" alignment="CENTER"
              maxWidth="Infinity"/>

    <!-- Notes -->
    <TextArea fx:id="notesArea" promptText="Add call notes — saved automatically…"
              prefHeight="96" wrapText="true" styleClass="call-notes">
        <VBox.vgrow>ALWAYS</VBox.vgrow>
    </TextArea>

    <!-- Footer: keyboard hints (left) + auto-save status (right) -->
    <HBox alignment="CENTER" spacing="8" maxWidth="Infinity">
        <Label text="Esc to hang up · M Mute · H Hold · K Keypad"
               styleClass="call-hint"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="notesStatus" text="" styleClass="call-save-status"
               visible="false" managed="false"/>
    </HBox>

</VBox>
