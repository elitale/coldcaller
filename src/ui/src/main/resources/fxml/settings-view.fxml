<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Settings view — grouped sections with per-section Save buttons.
  Controller: SettingsController (set via FXMLLoader.setController before load).
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1" styleClass="view-root">


    <!-- ── Toolbar ───────────────────────────────────────────────── -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="view-header">
            <Label text="Settings" styleClass="view-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" styleClass="caption"/>
        </HBox>
    </top>

    <!-- ── Scrollable content ────────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <BorderPane.margin><Insets left="32" right="32" bottom="24"/></BorderPane.margin>
            <content>
                <VBox spacing="20">
                    <padding><Insets top="8" bottom="32"/></padding>

                    <!-- ── General ─────────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="General" styleClass="title-2"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Default number" prefWidth="180"/>
                            <ComboBox fx:id="defaultNumberCombo" prefWidth="240"/>
                            <Button fx:id="refreshNumbersButton" text="Refresh"
                                    onAction="#onRefreshNumbers"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSaveGeneral"/>
                        </HBox>
                    </VBox>

                    <!-- ── Twilio ──────────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="Twilio" styleClass="title-2"/>
                        <Label text="Restart required for changes to take effect" styleClass="caption"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Account SID" prefWidth="180"/>
                            <TextField fx:id="twilioAccountSidField" prefWidth="320"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Auth Token" prefWidth="180"/>
                            <PasswordField fx:id="twilioAuthTokenField" prefWidth="320"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSaveTwilio"/>
                        </HBox>
                    </VBox>

                    <!-- ── SIP ─────────────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="SIP" styleClass="title-2"/>
                        <Label text="Restart required for changes to take effect" styleClass="caption"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Username" prefWidth="180"/>
                            <TextField fx:id="sipUsernameField" prefWidth="240"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Password" prefWidth="180"/>
                            <PasswordField fx:id="sipPasswordField" prefWidth="240"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Domain" prefWidth="180"/>
                            <TextField fx:id="sipDomainField" prefWidth="240"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Proxy" prefWidth="180"/>
                            <TextField fx:id="sipProxyField" prefWidth="240"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Proxy Port" prefWidth="180"/>
                            <Spinner fx:id="sipProxyPortSpinner" prefWidth="100" editable="true"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSaveSip"/>
                        </HBox>
                    </VBox>

                    <!-- ── Call Routing ────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="Call Routing" styleClass="title-2"/>
                        <Label text="Bridges your SIP phone to the phone network for outbound calls." styleClass="caption"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Status" prefWidth="180"/>
                            <Label fx:id="routingCurrentLabel" styleClass="caption"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Managed bridge" prefWidth="180"/>
                            <Button fx:id="routingAutoButton" text="Auto-configure" styleClass="accent"
                                    onAction="#onAutoConfigureRouting"/>
                            <Button fx:id="routingVerifyButton" text="Verify on Twilio"
                                    onAction="#onVerifyRouting"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Bridge URL" prefWidth="180"/>
                            <TextField fx:id="routingUrlField" prefWidth="320" promptText="https://…/pstn-bridge"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Caller ID fallback" prefWidth="180"/>
                            <TextField fx:id="routingCallerIdField" prefWidth="240" promptText="+1…  (optional)"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSaveRouting"/>
                        </HBox>
                    </VBox>

                    <!-- ── Audio ───────────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="Audio" styleClass="title-2"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Input Device" prefWidth="180"/>
                            <ComboBox fx:id="audioInputCombo" prefWidth="280"/>
                            <Button fx:id="inputTestButton" text="Test" onAction="#onToggleMicTest"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label prefWidth="180"/>
                            <ProgressBar fx:id="inputLevelBar" progress="0" prefWidth="280"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Output Device" prefWidth="180"/>
                            <ComboBox fx:id="audioOutputCombo" prefWidth="280"/>
                            <Button fx:id="outputTestButton" text="Test sound" onAction="#onTestSpeaker"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Jitter Buffer (ms)" prefWidth="180"/>
                            <Spinner fx:id="jitterBufferSpinner" prefWidth="100" editable="true"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSaveAudio"/>
                        </HBox>
                    </VBox>

                    <!-- ── Power Dialer ─────────────────────────────────────────── -->
                    <VBox styleClass="bg-elevated" spacing="12">
                        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                        <Label text="Power Dialer" styleClass="title-2"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="No-answer timeout (s)" prefWidth="200"/>
                            <Spinner fx:id="noAnswerTimeoutSpinner" prefWidth="100" editable="true"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Auto-advance delay (s)" prefWidth="200"/>
                            <Spinner fx:id="autoAdvanceDelaySpinner" prefWidth="100" editable="true"/>
                        </HBox>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Voicemail drop" prefWidth="200"/>
                            <CheckBox fx:id="voicemailDropCheckBox"/>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save" styleClass="accent" onAction="#onSavePowerDialer"/>
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
