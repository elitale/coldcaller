<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Dialer view — manual dial pad + recent calls.
  Controller: DialerController (set via FXMLLoader.setController before load).
-->
<VBox xmlns:fx="http://javafx.com/fxml/1"
                        spacing="16" alignment="TOP_CENTER" maxWidth="900">
                <padding><Insets top="28" bottom="24" left="28" right="28"/></padding>

    <!-- Screen heading -->
    <Label text="Dialer" styleClass="title-1"/>

    <!-- Number display — monospaced, right-aligned -->
    <Label fx:id="numberDisplay" text=""
           style="-fx-font-size: 28; -fx-font-family: monospace; -fx-min-height: 48;"
           maxWidth="Infinity" alignment="CENTER_RIGHT"/>

        <!-- Side-by-side content: dial pad (left) + recent calls (right) -->
        <HBox spacing="20" alignment="TOP_CENTER" maxWidth="Infinity">
                <children>
                        <VBox spacing="12" alignment="TOP_CENTER">

                                <!-- 4-row × 3-column dial pad -->
                                <GridPane hgap="8" vgap="8" alignment="CENTER">

                    <!-- Row 0 -->
                    <Button text="1" userData="1" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Button text="2" userData="2" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Button text="3" userData="3" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                    <!-- Row 1 -->
                    <Button text="4" userData="4" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Button text="5" userData="5" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Button text="6" userData="6" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                    <!-- Row 2 -->
                    <Button text="7" userData="7" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Button text="8" userData="8" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Button text="9" userData="9" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                    <!-- Row 3 -->
                    <Button text="*" userData="*" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Button text="0" userData="0" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Button text="#" userData="#" onAction="#onDigitPressed" styleClass="flat"
                            prefWidth="80" prefHeight="56"
                            GridPane.columnIndex="2" GridPane.rowIndex="3"/>

                </GridPane>

                <!-- Call + backspace + pop out -->
                <HBox spacing="8" alignment="CENTER">
                    <Button fx:id="callButton"      text="Call" onAction="#onCall"
                            prefWidth="140" prefHeight="48" styleClass="accent"/>
                    <Button fx:id="backspaceButton" text="&#x232B;" onAction="#onBackspace"
                            prefWidth="72"  prefHeight="48" styleClass="flat"/>
                    <Button fx:id="popOutButton" text="Pop Out" onAction="#onPopOut"
                            prefWidth="110" prefHeight="48" styleClass="flat"/>
                </HBox>
            </VBox>

            <VBox spacing="10" alignment="TOP_LEFT" prefWidth="320">
                <!-- Recent calls heading -->
                <Label text="Recent" styleClass="title-2"/>

                <!-- Recent calls list (populated by controller) -->
                <ListView fx:id="recentCallsList" prefHeight="360" prefWidth="320">
                    <VBox.vgrow>ALWAYS</VBox.vgrow>
                </ListView>
            </VBox>
        </children>
    </HBox>

</VBox>
