<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Dialer view — manual dial pad + recent calls.
  Controller: DialerController (set via FXMLLoader.setController before load).
-->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      spacing="20"
      alignment="TOP_LEFT"
      maxWidth="Infinity"
      maxHeight="Infinity"
      styleClass="dialer-root">
    <padding><Insets top="28" bottom="28" left="32" right="32"/></padding>

    <Label text="Dialer" styleClass="title-1"/>

    <HBox spacing="20" alignment="TOP_LEFT" maxWidth="Infinity" VBox.vgrow="ALWAYS">

        <!-- Dial pad — fixed width, does not stretch -->
        <VBox spacing="16" styleClass="dialer-panel" prefWidth="380" minWidth="380" maxWidth="380">
            <Label text="Enter Number" styleClass="dialer-section-title"/>

            <Label fx:id="numberDisplay"
                   text=""
                   maxWidth="Infinity"
                   alignment="CENTER_RIGHT"
                   styleClass="dialer-number-display"/>

            <GridPane hgap="12" vgap="12" alignment="CENTER" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.333" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="33.333" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="33.333" hgrow="ALWAYS"/>
                </columnConstraints>

                <Button text="1" userData="1" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Button text="2" userData="2" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Button text="3" userData="3" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                <Button text="4" userData="4" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Button text="5" userData="5" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Button text="6" userData="6" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                <Button text="7" userData="7" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Button text="8" userData="8" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Button text="9" userData="9" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                <Button text="*" userData="*" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Button text="0" userData="0" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Button text="#" userData="#" onAction="#onDigitPressed" styleClass="flat,dialer-key" prefHeight="60" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
            </GridPane>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="callButton" text="Call" onAction="#onCall" styleClass="accent,dialer-call" prefHeight="48" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="backspaceButton" text="&#x232B;" onAction="#onBackspace" styleClass="flat,dialer-backspace" prefWidth="68" prefHeight="48"/>
            </HBox>
        </VBox>

        <!-- Recent calls — fills remaining width, full height, scrollable -->
        <VBox spacing="14" styleClass="dialer-panel" HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
            <HBox alignment="CENTER_LEFT">
                <Label text="Recent Calls" styleClass="dialer-section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Today" styleClass="caption"/>
            </HBox>

            <ListView fx:id="recentCallsList" maxWidth="Infinity" maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>
</VBox>
